{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,

    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

		"outDir": "./dist",
    "rootDir": "./src"
  },
	"include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["dist", "node_modules", "webpack.config.js"]
}